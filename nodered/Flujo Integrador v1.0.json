        "func": "const partes = msg.payload.content.trim().split(/\\s+/);\n\nif (partes.length !== 2) {\n    return null; // no propaga el mensaje\n}\n\nconst humedad_minima = parseFloat(partes[0]);\nconst humedad_maxima = parseFloat(partes[1]);\n\nif (isNaN(humedad_minima) || isNaN(humedad_maxima)) {\n    return null;\n}\n\nif (humedad_minima >= humedad_maxima) {\n    return null;\n}\n\nmsg.humedad_minima = humedad_minima;\nmsg.humedad_maxima = humedad_maxima;\n\nreturn msg;",
