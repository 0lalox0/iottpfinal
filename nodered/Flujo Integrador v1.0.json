        "func": "if(global.keys().includes(\"chats\")){\n    const id = msg.payload.chatId;\n    if(!global.get(\"chats\").includes(id))\n        global.get(\"chats\").push(id)\n    msg = {}\n    msg.chats = global.get(\"chats\")\n    msg.plop=\"Fue por aqui\"\n    return msg\n}\nelse{\n    const id = msg.payload.chatId\n    global.set(\"chats\", [id]);\n    msg = {}\n    msg.keys = global.keys()\n    msg.chats = global.get(\"chats\")\n    msg.plop=\"Fue por allí\"\n    return msg\n}\n",
