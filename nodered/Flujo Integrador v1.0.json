        "name": "function 18",
        "func": "const partes = msg.payload.content.trim().split(/\\s+/);\n\nif (partes.length !== 2) {\n    return null; // no propaga el mensaje\n}\n\nconst temperatura_minima = parseFloat(partes[0]);\nconst temperatura_maxima = parseFloat(partes[1]);\n\nif (isNaN(temperatura_minima) || isNaN(temperatura_maxima)) {\n    return null;\n}\n\nif (temperatura_minima >= temperatura_maxima) {\n    return null;\n}\n\nmsg.temperatura_minima = temperatura_minima;\nmsg.temperatura_maxima = temperatura_maxima;\n\nreturn msg;",
