    {
        "id": "be6db7dcc95a648d",
        "type": "function",
        "z": "d20f0f62e4603041",
        "g": "bef545520eb9b7d4",
        "name": "function 16",
        "func": "const content = msg.payload.content;\n\nif(content === \"\"){\n    msg.payload.content = \"Por favor use el comando ingresando la primero la temperatura minima y separada de un espacio la temperatura maxima deseada a configurar los valores validos son desde 0 hasta 100 C°\";\n    return msg;\n}\n\nconst partes = msg.payload.content.trim().split(/\\s+/);\n\n// partes[0] = \"/comando\", partes[1] = min, partes[2] = max\nif (partes.length !== 2) {\n    node.warn(\"Formato inválido: \" + msg.payload.content);\n    msg.payload.content = \"Formato invalido ingrese la temperatura minima y la maxima separadas con un espacio nada mas\"\n    return msg;\n}\n\n  const temperatura_minima = parseFloat(partes[0]);\n  const temperatura_maxima = parseFloat(partes[1]);\nif (!(typeof temperatura_minima === 'number')){\n    msg.payload.content = \"La temperatura minima debe ser un numero\";\n} else if (!(temperatura_minima >= 0 && temperatura_minima <= 100)){\n    msg.payload.content = \"La temperatura minima estar de 0 a 100 C° \";\n} else if (!(typeof temperatura_maxima === 'number')) {\n    msg.payload.content = \"La temperatura Maxima debe ser un numero\";\n} else if (!(temperatura_maxima >= 0 && temperatura_maxima <= 100)) {\n    msg.payload.content = \"La temperatura minima estar de 0 a 100 C°\";\n} else if (temperatura_maxima <= temperatura_minima){\n    msg.payload.content = \"La temperatura maxima debe ser mayor a la temperatura minima\";\n} else{\n    msg.payload.content = \"Configuracion exitosa: Temperatura minima \"+ temperatura_minima +\" y Temperatura maxima \" + temperatura_maxima;\n}\n\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 880,
        "wires": [
