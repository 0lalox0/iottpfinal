        "name": "function 19",
        "func": "// partes[0] = min, partes[1] = max\nconst content = msg.payload.content;\n\nif (content === \"\") {\n    msg.payload.content = \"Por favor use el comando ingresando la primero la humedad minima y separada de un espacio la humedad maxima deseada a configurar los valores validos son desde 0 hasta 100 % \";\n    return msg;\n}\n\nconst partes = msg.payload.content.trim().split(/\\s+/);\n\n// partes[0] = min, partes[1] = max\nif (partes.length !== 2) {\n    node.warn(\"Formato inválido: \" + msg.payload.content);\n    msg.payload.content = \"Formato invalido ingrese la humedad minima y la maxima separadas con un espacio nada mas\";\n    return msg;\n}\n\nconst humedad_minima = parseFloat(partes[0]);\nconst humedad_maxima = parseFloat(partes[1]);\n\nif (!(typeof humedad_minima === 'number')) {\n    msg.payload.content = \"La humedad minima debe ser un numero\";\n} else if (!(humedad_minima >= 0 && humedad_minima <= 100)) {\n    msg.payload.content = \"La humedad minima debe estar de 0 a 100 %\";\n} else if (!(typeof humedad_maxima === 'number')) {\n    msg.payload.content = \"La humedad Maxima debe ser un numero\";\n} else if (!(humedad_maxima >= 0 && humedad_maxima <= 100)) {\n    msg.payload.content = \"La humedad maxima debe estar de 0 a 100 %\";\n} else if (humedad_maxima <= humedad_minima) {\n    msg.payload.content = \"La humedad maxima debe ser mayor a la humedad minima\";\n} else {\n    msg.payload.content = \"Configuracion exitosa: Humedad minima \" +\n        humedad_minima + \" y Humedad maxima \" + humedad_maxima;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
