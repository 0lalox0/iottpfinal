        "func": "let retorno = [[]]\nconst suscriptos = global.get(\"chats\");\n\nsuscriptos.forEach(function (suscripto) {\n    const temp = {};\n    temp.payload = {};\n    temp.payload.content = msg.mensaje\n    temp.payload.type = \"message\"\n    temp.payload.chatId = suscripto\n    retorno[0].push(temp)\n\n});\n\n\nreturn retorno;",
